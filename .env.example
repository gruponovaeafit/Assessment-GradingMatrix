# =============================================================
# VARIABLES DE ENTORNO — Assessment GradingMatrix
# =============================================================
# Copia este archivo como .env.local y completa los valores.
# NUNCA hagas commit de .env.local con valores reales.
# =============================================================

# ----------------------------
# Supabase
# ----------------------------

# URL pública del proyecto Supabase (se puede exponer al frontend)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública (anon/publishable key) — segura para el frontend
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# ⚠️ Service Role Key — SOLO para uso server-side (API routes, scripts)
# Esta clave evita todas las políticas de Row Level Security (RLS).
# Nunca la expongas al cliente ni la incluyas en variables NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=
